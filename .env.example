# === Build Args ===
VLLM_OMNI_VERSION=v0.16.0
TORCH_CUDA_ARCH_LIST=8.0;8.6;8.9;9.0

# === Model ===
MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
# Options: Qwen/Qwen3-TTS-12Hz-1.7B-Base (voice clone)
#          Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
#          Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
#          Qwen/Qwen3-TTS-12Hz-0.6B-Base
#          Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice

# === Server ===
PORT=8091
TRUST_REMOTE_CODE=true
ENFORCE_EAGER=true

# === GPU ===
GPU_COUNT=1
GPU_MEMORY_UTILIZATION_STAGE0=0.3
GPU_MEMORY_UTILIZATION_STAGE1=0.3

# === Engine ===
MAX_NUM_SEQS=10
MAX_MODEL_LEN_STAGE0=4096
MAX_MODEL_LEN_STAGE1=32768

# === Sampling (Stage 0 - Talker) ===
TEMPERATURE=0.9
TOP_K=50
TOP_P=1.0
MAX_TOKENS=4096
REPETITION_PENALTY=1.05
SEED=42

# === HuggingFace ===
HF_TOKEN=
HF_CACHE_DIR=
